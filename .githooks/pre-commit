#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
gradlew="$repo_root/gradlew"

staged_kotlin_files=()
while IFS= read -r -d '' file; do
  staged_kotlin_files+=("$file")
done < <(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR -z -- '*.kt' '*.kts')

if [ ${#staged_kotlin_files[@]} -eq 0 ]; then
  exit 0
fi

if [ ! -x "$gradlew" ]; then
  echo "pre-commit: gradle wrapper not found or not executable: $gradlew" >&2
  exit 1
fi

preferred_gradle_user_home=""
if [ -n "${GRADLE_USER_HOME:-}" ]; then
  preferred_gradle_user_home="$GRADLE_USER_HOME"
elif [ -n "${HOME:-}" ]; then
  preferred_gradle_user_home="$HOME/.gradle"
fi

hook_gradle_user_home="$preferred_gradle_user_home"
if [ -n "$hook_gradle_user_home" ]; then
  probe_file="$hook_gradle_user_home/.pre-commit-write-test-$$"
  if ! mkdir -p "$hook_gradle_user_home" 2>/dev/null || ! ( : > "$probe_file" ) 2>/dev/null; then
    hook_gradle_user_home=""
  else
    rm -f "$probe_file"
  fi
fi

if [ -z "$hook_gradle_user_home" ]; then
  hook_gradle_user_home="$repo_root/.gradle/pre-commit-user-home"
  mkdir -p "$hook_gradle_user_home"
  echo "pre-commit: falling back to repo-local GRADLE_USER_HOME at $hook_gradle_user_home"
fi

echo "pre-commit: running $gradlew ktlintFormat on staged Kotlin files..."
GRADLE_USER_HOME="$hook_gradle_user_home" \
  "$gradlew" --project-dir "$repo_root" --no-daemon \
  ktlintFormat -Pktlint.filter="${staged_kotlin_files[*]}"

# Re-stage files that were modified by formatter.
git -C "$repo_root" add -- "${staged_kotlin_files[@]}"
